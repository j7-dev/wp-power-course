{
	"name": "power-course",
	"private": true,
	"version": "1.2.4",
	"author": "J7 <j7.dev.gg@gmail.com>",
	"type": "module",
	"scripts": {
		"bootstrap": "composer install --no-interaction",
		"dev": "vite",
		"build": "pnpm run i18n:build && vite build",
		"build:wp": "vite --config vite.config-for-wp.ts build",
		"preview": "vite preview",
		"format": "prettier-eslint --write \"js/src/**/*.tsx\"",
		"lint:php": "phpcbf && phpcs inc --report=full -v && phpstan analyze inc --memory-limit=4096M",
		"lint:ts": "npx eslint \"js/src/**/*.{ts,tsx}\" --ext .ts,.tsx --fix --rule \"no-unused-vars: off\"",
		"release": "env-cmd -f ./.env release-it patch --ci --verbose --config ./release/.release-it.cjs",
		"release:build-only": "env-cmd -f ./.env release-it patch --ci --verbose --config ./release/.release-it.cjs --build-only",
		"release:patch": "env-cmd -f ./.env release-it patch --ci --verbose --config ./release/.release-it.cjs",
		"release:minor": "env-cmd -f ./.env release-it minor --ci --verbose --config ./release/.release-it.cjs",
		"release:major": "env-cmd -f ./.env release-it major --ci --verbose --config ./release/.release-it.cjs",
		"zip": "env-cmd -f ./.env node ./release/zip.cjs",
		"create:release": "env-cmd -f ./.env node ./release/create-release.cjs",
		"sync:version": "wp-update-project-version -s package.json -p plugin.php",
		"replace-string": "node ./replace-string.cjs",
		"env:start": "npx wp-env start",
		"env:stop": "npx wp-env stop",
		"env:destroy": "npx wp-env destroy",
		"env:clean": "npx wp-env clean all",
		"test:e2e": "cd tests/e2e && npx playwright test",
		"test:e2e:admin": "cd tests/e2e && npx playwright test --project=admin",
		"test:e2e:frontend": "cd tests/e2e && npx playwright test --project=frontend",
		"test:e2e:integration": "cd tests/e2e && npx playwright test --project=integration",
		"test:e2e:ui": "cd tests/e2e && npx playwright test --ui",
		"test:e2e:debug": "cd tests/e2e && npx playwright test --debug",
		"test:phpunit": "npx wp-env run tests-cli --env-cwd=wp-content/plugins/power-course composer run test",
		"i18n:pot": "npx --yes @wp-blocks/make-pot@^1.6 . languages --slug=power-course --domain=plugin --exclude=node_modules,vendor,tests,release,js/dist,languages",
		"i18n:mo": "wp i18n make-mo languages",
		"i18n:json": "node scripts/i18n-make-json.mjs",
		"i18n:build": "pnpm run i18n:pot && pnpm run i18n:mo && pnpm run i18n:json"
	},
	"dependencies": {
		"@ant-design/charts": "^2.3.0",
		"@ant-design/cssinjs": "1.23.0",
		"@ant-design/icons": "^6.0.0",
		"@ant-design/plots": "2.5.0",
		"@ant-design/pro-components": "^2.8.7",
		"@ant-design/pro-editor": "^1.3.0",
		"@arco-themes/react-easy-email-theme": "^0.0.3",
		"@blocknote/code-block": "^0.31.2",
		"@blocknote/core": "0.30.0",
		"@blocknote/mantine": "0.30.0",
		"@blocknote/react": "0.30.0",
		"@pdf-lib/fontkit": "^1.1.1",
		"@refinedev/antd": "5.46.1",
		"@refinedev/cli": "2.16.46",
		"@refinedev/core": "4.57.9",
		"@refinedev/inferencer": "4.7.1",
		"@refinedev/react-router": "^1.0.1",
		"@refinedev/simple-rest": "5.0.10",
		"@tanstack/query-core": "^4.39.2",
		"@tanstack/react-query": "4.39.2",
		"@uidotdev/usehooks": "^2.4.1",
		"@vidstack/react": "^1.12.13",
		"antd": "5.26.1",
		"antd-img-crop": "4.25.0",
		"antd-style": "^3.7.1",
		"antd-toolkit": "1.3.221",
		"axios": "^1.10.0",
		"dayjs": "1.11.13",
		"hls.js": "^1.6.5",
		"immer": "^10.1.1",
		"j7-easy-email-core": "4.17.0",
		"j7-easy-email-editor": "4.17.0",
		"j7-easy-email-extensions": "4.17.1",
		"jotai": "^2.12.5",
		"lodash-es": "4.17.21",
		"media-icons": "^1.1.5",
