# ══════════════════════════════════════════════
# Power Course 測試環境設定
# 複製此檔為 .env 並填入正確值
# ══════════════════════════════════════════════

# ── 測試站台 ──────────────────────────────────
# E2E 測試的目標網站（需可公開連線，或透過 Cloudflare Tunnel）
TEST_SITE_URL=https://your-test-site.example.com
TEST_ADMIN_URL=https://your-test-site.example.com/wp-admin

# ── WordPress 管理員帳號 ────────────────────────
TEST_USERNAME=your_username
TEST_PASSWORD=your_password

# ── CI 模式 ────────────────────────────────────
# true = headless（無視窗），false = 有頭模式（本地 debug 用）
CI=false

# ── WooCommerce REST API Keys ──────────────────
# 初始可留空（E2E 使用 nonce-based auth）
WC_API_KEY=
WC_API_SECRET=
